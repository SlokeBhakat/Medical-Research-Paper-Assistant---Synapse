# Synapse Environmental Variables Template
# Copy this file to .env.local and fill in your keys.
# NEVER commit your real .env.local to a public repository.

# Groq API Key (for LLM reasoning)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (for Vector Embeddings)
GOOGLE_GENAI_API_KEY=your_google_gemini_key_here
